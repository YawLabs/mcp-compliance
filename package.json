{
  "name": "@yawlabs/mcp-compliance",
  "version": "0.16.2",
  "mcpName": "io.github.YawLabs/mcp-compliance",
  "description": "CLI tool and MCP server that tests MCP servers for spec compliance",
  "license": "MIT",
  "author": "Yaw Labs <contact@yaw.sh> (https://yaw.sh)",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/runner.js",
      "types": "./dist/runner.d.ts"
    },
    "./mcp/server": {
      "import": "./dist/mcp/server.js",
      "types": "./dist/mcp/server.d.ts"
    },
    "./schemas/*.json": "./schemas/*.json"
  },
  "main": "./dist/runner.js",
  "types": "./dist/runner.d.ts",
  "bin": {
    "mcp-compliance": "dist/index.js"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "schemas",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "test:ci": "npm run build && npm test",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.4.1",
    "commander": "^14.0.3",
    "undici": "^7.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.5.2",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "postject": "^1.0.0-alpha.6",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "compliance",
    "testing",
    "cli",
    "mcp-server",
    "spec",
    "validation",
    "json-rpc",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YawLabs/mcp-compliance.git"
  },
  "bugs": {
    "url": "https://github.com/YawLabs/mcp-compliance/issues"
  },
  "homepage": "https://github.com/YawLabs/mcp-compliance"
}
